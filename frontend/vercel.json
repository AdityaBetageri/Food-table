{
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/aboutUs",
      "destination": "/about-us.html"
    },
    {
      "source": "/about-us",
      "destination": "/about-us.html"
    },
    {
      "source": "/(.*)",
      "destination": "/app.html"
    }
  ]
}
